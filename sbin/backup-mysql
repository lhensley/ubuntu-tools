#!/bin/bash

# Dumps all the MySQL data (except system info)
# And stores the results
# Clean-up started 2026-06-17

# Set DEBUG_MODE to make the script
DEBUG_MODE=false; if $DEBUG_MODE ; then echo "DEBUG EXECUTING $0 line ${LINENO}" $(date +"%F %T.%3N %Z") ; fi
# if $DEBUG_MODE ; then echo "DEBUG MARKER $0 line ${LINENO}" $(date +"%F %T.%3N %Z") ; fi

# Include script setup file
	source script-setup
	if [ ! $FUNCTIONS_ARE_DEFINED ]; then echo $0: Functions not defined. Aborting; logger $0: Functions not defined. Aborting; exit 1; fi
	if [ ! $VARIABLES_ARE_DEFINED ]; then echo $0: Variables not defined. Aborting; logger $0: Variables not defined. Aborting; exit 1; fi

# Require root
	f_require_root

# CHECK FOR ENOUGH ARGUMENTS (change 0 to minimum arguments and flesh out Usage)
if [ $# -lt 0 ]; 
    then echo "$EXIT_CODE_DESC_DIRECTORY_NOT_FOUND" > /dev/stderr
	echo "Usage: $(basename $0)" > /dev/stderr
	exit $EXIT_CODE_DIRECTORY_NOT_FOUND
fi

# Debugging checkpoint
if $DEBUG_MODE ; then echo "DEBUG MARKER $0 line ${LINENO}" $(date +"%F %T.%3N %Z") ; fi

# Set variables
WORKING_DIR="/tmp/mysql-$UUID"
WORKING_DUMP="$WORKING_DIR/$HOSTNAME.sql"
TIMESTAMP="$(/bin/date '+%Y-%m-%d-%H-%M-%S-%Z')"

# echo WORKING_DIR="/tmp/mysql-$UUID"
echo WORKING_DUMP=$WORKING_DUMP
echo TIMESTAMP=$TIMESTAMP
# echo mkdir --mode=600 -p $WORKING_DIR
mkdir --mode=600 -p $WORKING_DIR

# echo "$(/bin/date '+%Y-%m-%d-%H-%M-%S-%Z'): Dumping all user databases. (This takes a while.)" > /dev/stderr
echo "Dumping all user databases. (This takes a while.)" > /dev/stderr
mysqldump --databases \
    $(for d in $(mysql -Bse 'show databases') ;
        do if [ "$d" != "information_schema" ] \
        && [ "$d" != "mysql" ] \
        && [ "$d" != "performance_schema" ] \
        && [ "$d" != "phpmyadmin" ] \
        && [ "$d" != "sys" ]; \
        then printf "%s " "$d"; fi; done) \
        --triggers --events --routines > $WORKING_DUMP

# echo chmod -R 600 $WORKING_DIR/*
chmod -R 600 $WORKING_DIR/*

############################################################################
# IMPORTANT: At this point, the $WORKING_DUMP is finished. 
# Everything else is compessing, moving it around, and naming it as helpful.

