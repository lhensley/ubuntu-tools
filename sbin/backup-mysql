mkdir --mode=600 -p "$ADMIN_HOME_DIR/backups/MySQL"
echo mv $WORKING_DUMP $ADMIN_HOME_DIR/backups/MySQL/
mv $WORKING_DUMP $ADMIN_HOME_DIR/backups/MySQL/

